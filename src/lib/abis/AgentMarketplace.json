{
  "abi": [
    {
      "type": "constructor",
      "inputs": [
        { "name": "_agentRegistry", "type": "address" },
        { "name": "_treasury",      "type": "address" }
      ],
      "stateMutability": "nonpayable"
    },
    {
      "type": "function",
      "name": "buyAgent",
      "inputs": [
        { "name": "agentId",            "type": "uint256" },
        { "name": "seller",             "type": "address" },
        { "name": "mode",               "type": "uint8"   },
        { "name": "newCapabilityHash",  "type": "bytes32" },
        { "name": "newSealedKey",       "type": "bytes"   },
        { "name": "oracleProof",        "type": "bytes"   }
      ],
      "outputs": [{ "name": "orderId", "type": "uint256" }],
      "stateMutability": "payable"
    },
    {
      "type": "function",
      "name": "completeTransfer",
      "inputs": [{ "name": "orderId", "type": "uint256" }],
      "outputs": [],
      "stateMutability": "nonpayable"
    },
    {
      "type": "function",
      "name": "completeClone",
      "inputs": [
        { "name": "orderId",     "type": "uint256" },
        { "name": "newAgentId",  "type": "uint256" }
      ],
      "outputs": [],
      "stateMutability": "nonpayable"
    },
    {
      "type": "function",
      "name": "refundExpired",
      "inputs": [{ "name": "orderId", "type": "uint256" }],
      "outputs": [],
      "stateMutability": "nonpayable"
    },
    {
      "type": "function",
      "name": "getOrder",
      "inputs": [{ "name": "orderId", "type": "uint256" }],
      "outputs": [{
        "name": "",
        "type": "tuple",
        "components": [
          { "name": "buyer",        "type": "address" },
          { "name": "seller",       "type": "address" },
          { "name": "agentId",      "type": "uint256" },
          { "name": "finalAgentId", "type": "uint256" },
          { "name": "amountWei",    "type": "uint96"  },
          { "name": "createdAt",    "type": "uint64"  },
          { "name": "expiresAt",    "type": "uint64"  },
          { "name": "mode",         "type": "uint8"   },
          { "name": "status",       "type": "uint8"   }
        ]
      }],
      "stateMutability": "view"
    },
    {
      "type": "function",
      "name": "getBuyerOrders",
      "inputs": [{ "name": "buyer", "type": "address" }],
      "outputs": [{ "name": "", "type": "uint256[]" }],
      "stateMutability": "view"
    },
    {
      "type": "function",
      "name": "getSellerOrders",
      "inputs": [{ "name": "seller", "type": "address" }],
      "outputs": [{ "name": "", "type": "uint256[]" }],
      "stateMutability": "view"
    },
    {
      "type": "function",
      "name": "protocolFeeBps",
      "inputs": [],
      "outputs": [{ "name": "", "type": "uint16" }],
      "stateMutability": "view"
    },
    {
      "type": "function",
      "name": "escrowDuration",
      "inputs": [],
      "outputs": [{ "name": "", "type": "uint32" }],
      "stateMutability": "view"
    },
    {
      "type": "event",
      "name": "BuyRequested",
      "anonymous": false,
      "inputs": [
        { "name": "orderId",           "type": "uint256", "indexed": true },
        { "name": "buyer",             "type": "address", "indexed": true },
        { "name": "seller",            "type": "address", "indexed": true },
        { "name": "agentId",           "type": "uint256", "indexed": false },
        { "name": "amountWei",         "type": "uint96",  "indexed": false },
        { "name": "mode",              "type": "uint8",   "indexed": false },
        { "name": "newCapabilityHash", "type": "bytes32", "indexed": false },
        { "name": "newSealedKey",      "type": "bytes",   "indexed": false },
        { "name": "oracleProof",       "type": "bytes",   "indexed": false },
        { "name": "expiresAt",         "type": "uint64",  "indexed": false }
      ]
    },
    {
      "type": "event",
      "name": "SaleCompleted",
      "anonymous": false,
      "inputs": [
        { "name": "orderId",      "type": "uint256", "indexed": true },
        { "name": "seller",       "type": "address", "indexed": true },
        { "name": "buyer",        "type": "address", "indexed": true },
        { "name": "sellerPayout", "type": "uint96",  "indexed": false },
        { "name": "protocolFee",  "type": "uint96",  "indexed": false },
        { "name": "finalAgentId", "type": "uint256", "indexed": false },
        { "name": "mode",         "type": "uint8",   "indexed": false }
      ]
    },
    {
      "type": "event",
      "name": "RefundIssued",
      "anonymous": false,
      "inputs": [
        { "name": "orderId",   "type": "uint256", "indexed": true },
        { "name": "buyer",     "type": "address", "indexed": true },
        { "name": "amountWei", "type": "uint96",  "indexed": false }
      ]
    }
  ]
}
